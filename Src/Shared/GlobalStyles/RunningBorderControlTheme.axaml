<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:components="using:KrolikGR.Src.Shared.GlobalComponents.RunningBorder">
    <ControlTheme x:Key="{x:Type components:RunningBorder}" TargetType="components:RunningBorder">
        <Setter Property="BaseBorderColor" Value="{DynamicResource SystemBaseLowColor}" />
        <Setter Property="RunningColor" Value="{DynamicResource SystemAccentColor}" />
    </ControlTheme>
</ResourceDictionary>
