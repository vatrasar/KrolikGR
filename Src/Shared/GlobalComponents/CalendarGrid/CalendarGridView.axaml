<rxui:ReactiveUserControl x:TypeArguments="local:CalendarGridViewModel"
             x:DataType="local:CalendarGridViewModel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:KrolikGR.Src.Shared.GlobalComponents.CalendarGrid"
             xmlns:tile="using:KrolikGR.Src.Shared.GlobalComponents.CalendarDayTile"
             xmlns:models="using:KrolikGR.Src.Core.Models.Calendar"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:rxui="http://reactiveui.net"
             x:Class="KrolikGR.Src.Shared.GlobalComponents.CalendarGrid.CalendarGridView"
             x:Name="CalendarGridRoot"
             Background="Transparent">

    <Grid RowDefinitions="Auto, Auto, *">
        
        <!-- Header: Month/Year navigation -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,16">
            <Button x:Name="PreviousMonthButton"
                    Grid.Column="0" 
                    Classes="Ghost" 
                    Theme="{DynamicResource TransparentButton}">
                <materialIcons:MaterialIcon Kind="ChevronLeft" Width="24" Height="24" />
            </Button>
            
            <TextBlock x:Name="MonthYearText"
                       Grid.Column="1" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" />
            
            <Button x:Name="NextMonthButton"
                    Grid.Column="2" 
                    Classes="Ghost" 
                    Theme="{DynamicResource TransparentButton}">
                <materialIcons:MaterialIcon Kind="ChevronRight" Width="24" Height="24" />
            </Button>
        </Grid>
        
        <!-- Days of week header -->
        <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="*,*,*,*,*,*,*">
            <!-- Hardcoding Polish days for now as it's the required language -->
            <TextBlock Grid.Column="0" Text="Pon" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="1" Text="Wto" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="2" Text="Śro" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="3" Text="Czw" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="4" Text="Pią" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="5" Text="Sob" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="6" Text="Nie" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Grid>

        <!-- Calendar Days Grid -->
        <ItemsControl x:Name="DaysItemsControl" Grid.Row="2">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Rows="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="tile:CalendarDayTileViewModel">
                    <tile:CalendarDayTileView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</rxui:ReactiveUserControl>
