<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:KrolikGR.Src.Core.Models.Calendar"
             x:Class="KrolikGR.Src.Shared.GlobalComponents.CalendarDayTile.CalendarDayTileView"
             x:DataType="models:CalendarDay"
             x:Name="DayTileControl"
             Background="Transparent">
    
    <Border BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Margin="4" 
            Padding="8"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Classes.not-current-month="{Binding !IsCurrentMonth}">
        <Border.Styles>
            <Style Selector="Border.not-current-month">
                <Setter Property="Opacity" Value="0.4" />
            </Style>
        </Border.Styles>
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            </Transitions>
        </Border.Transitions>
        
        <Grid RowDefinitions="Auto, *, Auto">
            <TextBlock x:Name="DateText" 
                       Grid.Row="0" 
                       Text="{Binding Date.Day}" 
                       FontWeight="SemiBold" 
                       FontSize="16" />
            
            <!-- Percentage line -->
            <ProgressBar x:Name="FillProgressBar"
                         Grid.Row="2" 
                         Height="6" 
                         Margin="0,8,0,0" 
                         Minimum="0" 
                         Maximum="100" 
                         Value="{Binding FillPercentage}" 
                         ShowProgressText="False" />
        </Grid>
    </Border>
</UserControl>
