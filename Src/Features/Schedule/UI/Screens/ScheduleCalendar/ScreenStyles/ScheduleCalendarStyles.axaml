<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.SummaryPanelContainer">
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                <ThicknessTransition Property="Margin" Duration="0:0:0.3" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.SummaryPanelContainer.hidden">
        <Setter Property="Width" Value="0" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Border.SummaryPanelContainer:not(.hidden)">
        <Setter Property="Width" Value="320" />
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Margin" Value="16,0,0,0" />
    </Style>

    <Style Selector="Button.ClosePanelButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.ClosePanelButton:pointerover">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
    </Style>

</Styles>
