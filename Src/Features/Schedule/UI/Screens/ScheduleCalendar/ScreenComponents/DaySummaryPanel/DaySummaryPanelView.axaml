<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:KrolikGR.Src.Features.Schedule.UI.Screens.ScheduleCalendar.ScreenComponents.DaySummaryPanel"
             xmlns:rxui="http://reactiveui.net"
             x:Class="KrolikGR.Src.Features.Schedule.UI.Screens.ScheduleCalendar.ScreenComponents.DaySummaryPanel.DaySummaryPanelView"
             x:TypeArguments="local:DaySummaryPanelViewModel"
             x:DataType="local:DaySummaryPanelViewModel"
             Background="Transparent">

    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        
        <Grid RowDefinitions="*, Auto">
            
            <StackPanel Grid.Row="0" Spacing="16">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock x:Name="DateText"
                               FontSize="20" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    
                    <Button x:Name="CloseButton"
                            Grid.Column="1" 
                            Classes="ClosePanelButton"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Zamknij">
                        <Path x:Name="ClosePath"
                              Data="M 0 0 L 10 10 M 10 0 L 0 10" 
                              StrokeThickness="1.5" 
                              Width="10" 
                              Height="10" />
                    </Button>
                </Grid>
                
                <TextBlock Text="Zapełnienie etatów:" 
                           FontWeight="SemiBold" 
                           Margin="0,8,0,0"/>
                
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*, Auto" Margin="0,8,0,16">
                    <!-- Crew -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,16,12">
                        <TextBlock Text="Załoga" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <ProgressBar x:Name="CrewProgressBar" Minimum="0" Maximum="100" Height="8" ShowProgressText="False" />
                    </StackPanel>
                    <TextBlock x:Name="CrewPercentageText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,12" />
                    
                    <!-- Managers -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,0,16,12">
                        <TextBlock Text="Managerowie" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <ProgressBar x:Name="ManagersProgressBar" Minimum="0" Maximum="100" Height="8" ShowProgressText="False" Foreground="{DynamicResource SystemAccentColor}" />
                    </StackPanel>
                    <TextBlock x:Name="ManagersPercentageText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,12" />
                    
                    <!-- Maintenance -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                        <TextBlock Text="Sprzątacze" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <ProgressBar x:Name="MaintenanceProgressBar" Minimum="0" Maximum="100" Height="8" ShowProgressText="False" Foreground="{DynamicResource SystemAccentColor}" />
                    </StackPanel>
                    <TextBlock x:Name="MaintenancePercentageText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom" />
                </Grid>
            </StackPanel>
            
            <!-- Actions at the bottom -->
            <StackPanel Grid.Row="1" Spacing="8">
                
                <Button x:Name="AddCrewButton"
                        Content="Dodaj załogę" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"
                        Classes="Primary" />
                
                <Button x:Name="ShowDayDetailsButton"
                        Content="Pokaż szczegóły dnia" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" />
            </StackPanel>
            
        </Grid>
    </Border>
</rxui:ReactiveUserControl>
