<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KrolikGR.App"
             xmlns:local="using:KrolikGR"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://KrolikGR/Src/Shared/GlobalStyles/RunningBorderControlTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://KrolikGR/Src/Shared/GlobalStyles/AppThemeStyles.axaml" />
        <materialIcons:MaterialIconStyles />
    </Application.Styles>
</Application>